# =========================================================================
# Apple Search Ads — OAuth (modern self-managed-certificate flow)
#
# 1. Generate a P-256 keypair locally:
#      openssl ecparam -genkey -name prime256v1 -noout -out asa_private_key.pem
#      openssl ec -in asa_private_key.pem -pubout -out asa_public_key.pem
# 2. Log in to https://app.searchads.apple.com AS THE API USER (a dedicated
#    Apple ID with role "API Account Manager"). Go to Account Settings → API.
#    Paste the contents of asa_public_key.pem into the "Public Key" box and
#    click "Generate API Client".
# 3. Apple returns three values — copy them here.
#
# clientId AND teamId are typically identical for this flow (Apple uses the
# same SEARCHADS.<uuid> for both); the agent treats them as separate vars
# in case Apple splits them in the future.
# =========================================================================
ASA_CLIENT_ID=SEARCHADS.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASA_TEAM_ID=SEARCHADS.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASA_KEY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Either path to the .pem on disk...
ASA_PRIVATE_KEY_PATH=~/.appstoreconnect/private_keys/asa_private_key.pem
# ...or the PEM contents inline (Render-friendly; newlines as real newlines OR \n).
ASA_PRIVATE_KEY_PEM=

# Org ID — returned by `make auth-check` (GET /api/v5/acls).
ASA_ORG_ID=
# Match the org's configured time zone (Account Settings → General). The
# default is America/New_York unless you've changed it.
ASA_TIME_ZONE=America/New_York

# =========================================================================
# Neon Postgres (Visage backend — READ ONLY usage)
# Pull the live value from Render: srv-d7i28kcvikkc73aiovog → env → DATABASE_URL
# =========================================================================
BACKEND_DATABASE_URL=

# =========================================================================
# Agent's own Postgres (ads_snapshots, recommendations, decisions).
# Can be the same Neon project as the backend (different schema) or a
# separate database. Default schema is `ads_agent`.
# =========================================================================
AGENT_DATABASE_URL=
AGENT_DB_SCHEMA=ads_agent

# =========================================================================
# Slack — daily digest webhook (incoming-webhook URL, channel encoded in it)
# =========================================================================
SLACK_WEBHOOK_URL=

# =========================================================================
# Anthropic (Phase 3 only — leave empty until then)
# =========================================================================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# =========================================================================
# App Store Connect — used only by scripts/upload_screenshots.py
# DIFFERENT KEY from ASA. This is the legacy `.p8` you generated via
# App Store Connect → Users and Access → Integrations → App Store Connect API.
# =========================================================================
ASC_KEY_ID=NMKX98FQ8B
ASC_ISSUER_ID=3207b23a-16e9-49ca-893b-4dda7d4abfb9
ASC_PRIVATE_KEY_PATH=~/.appstoreconnect/private_keys/AuthKey_NMKX98FQ8B.p8
# ASC_PRIVATE_KEY_PEM=     # inline alternative, Render-friendly
ASC_BUNDLE_ID=com.pgammedia.visage

# =========================================================================
# Behavior
# =========================================================================
REPORT_LOOKBACK_HOURS=24
MIN_DATA_AGE_HOURS=48
CURRENCY=USD

# =========================================================================
# Targets / guardrails (used by Phase 2 recommender)
# =========================================================================
TARGET_CPA_PAID_USD=15.00
HARD_CAP_CPT_USD=5.00
MAX_DAILY_BUDGET_INCREASE_PCT=25
