# =========================================================================
# Apple Search Ads — JWT auth
# Apple Search Ads uses an App Store Connect-style .p8 key but a DIFFERENT
# audience claim. Same key file as App Store Connect API; new flow.
# =========================================================================
ASA_KEY_ID=NMKX98FQ8B
ASA_ISSUER_ID=3207b23a-16e9-49ca-893b-4dda7d4abfb9
# Either provide the path to the .p8 file...
ASA_PRIVATE_KEY_PATH=
# ...or paste the PEM contents inline (Render-friendly; newlines as \n).
ASA_PRIVATE_KEY_PEM=
# Filled in once `GET /api/v5/acls` returns the org for this Apple ID.
ASA_ORG_ID=

# =========================================================================
# Neon Postgres (Visage backend — READ ONLY usage)
# Pull the live value from Render: srv-d7i28kcvikkc73aiovog → env → DATABASE_URL
# =========================================================================
BACKEND_DATABASE_URL=

# =========================================================================
# Agent's own Postgres (ads_snapshots, recommendations, decisions).
# Can be the same Neon project as the backend (different schema) or a
# separate database. Default schema is `ads_agent`.
# =========================================================================
AGENT_DATABASE_URL=
AGENT_DB_SCHEMA=ads_agent

# =========================================================================
# Slack — daily digest webhook (incoming-webhook URL, channel encoded in it)
# =========================================================================
SLACK_WEBHOOK_URL=

# =========================================================================
# Anthropic (Phase 3 only — leave empty until then)
# =========================================================================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# =========================================================================
# Behavior
# =========================================================================
# Lookback window for the daily report (hours). Apple data has ~2-3h lag
# and MMP postbacks take up to 48h, so 24 is the standard cron window but
# you can backfill with e.g. 168 (7 days) on first run.
REPORT_LOOKBACK_HOURS=24
# Decision lock-out: don't act on data younger than this many hours.
MIN_DATA_AGE_HOURS=48
# Currency — ASA reports come back in this currency.
CURRENCY=USD
# Time zone passed to ASA reporting (`timeZone` param). UTC or ORTZ.
ASA_TIME_ZONE=UTC

# =========================================================================
# Targets / guardrails (used by Phase 2 recommender)
# =========================================================================
TARGET_CPA_PAID_USD=15.00
HARD_CAP_CPT_USD=5.00
MAX_DAILY_BUDGET_INCREASE_PCT=25
